# Backend API root. In dev this is also used as the Vite proxy target.
# Example: http://172.90.10.13:9910
VITE_BASE_PATH=

# Firebase Web API key (Identity Toolkit). Get it from Firebase console.
VITE_FIREBASE_KEY=

# Client type sent to the login API (e.g. CLIENT_TYPE_WEB)
VITE_CLIENT_TYPE=CLIENT_TYPE_WEB

# Path prefix for stats endpoints (default: /api/v1/stats)
VITE_STATS_PATH_PREFIX=/api/v1/stats
